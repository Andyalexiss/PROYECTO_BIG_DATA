      <column caption='Es_Horario_Critico' datatype='string' name='[Calculation_2051712098717696]' role='dimension' type='nominal'>
        <calculation class='tableau' formula='IF [momento_dia] = &quot;Noche (10pm-2am)&quot; &#13;&#10;THEN &quot;Horario Crítico (10pm-2am)&quot; &#13;&#10;ELSE &quot;Resto del día&quot; &#13;&#10;END' />
